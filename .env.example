# Stripe keys — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Base URL of your deployment (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3009

# DCS Runtime
DCS_RUNTIME_URL=http://localhost:4000
DCS_INTERNAL_TOKEN=

# Payment (Base Sepolia simulation)
NEXT_PUBLIC_PAYMENT_SIMULATION_MODE=true
NEXT_PUBLIC_PAYMENT_SIM_CHAIN_ID=84532
NEXT_PUBLIC_PAYMENT_SIM_NETWORK_NAME=Base Sepolia
NEXT_PUBLIC_PAYMENT_SIM_USDC_ADDRESS=0x...
NEXT_PUBLIC_PAYMENT_SIM_PAY_TO_ADDRESS=0x...
NEXT_PUBLIC_PAYMENT_SIM_CONFIRMATIONS_REQUIRED=2
NEXT_PUBLIC_PAYMENT_SIM_EXPLORER_URL=https://sepolia.basescan.org

# Notifications
NEXT_PUBLIC_NOTIFICATION_CHAIN_ID=84532
NEXT_PUBLIC_NOTIFICATION_CHAIN_NAME=Base Sepolia
NEXT_PUBLIC_NOTIFICATION_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_NOTIFICATION_PUBLISHER_ADDRESS=

# WalletConnect (optional)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Webhook receiver — set after running: npm run register:webhook
DECOMM_WEBHOOK_SECRET=whsec_...
